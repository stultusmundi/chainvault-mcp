# ChainVault MCP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials.

# Master vault password (used by CLI commands when not running TUI)
# In production, prefer the interactive TUI prompt instead of this env var.
CHAINVAULT_PASSWORD=

# Custom vault storage path (default: ~/.chainvault)
# CHAINVAULT_PATH=~/.chainvault

# Claude Code OAuth token (required for agent e2e tests in tests/agent-e2e/)
# CLAUDE_CODE_OAUTH_TOKEN=
